# Single stage build for API - bun handles workspaces natively
FROM oven/bun:1-alpine

WORKDIR /app

# Copy monorepo
COPY package.json bun.lock ./
COPY apps/ ./apps/
COPY packages/ ./packages/

# Install and build
RUN bun install
RUN bun run --filter=@agentops/api build

# Run
EXPOSE 3001 3002

ENTRYPOINT ["bun", "run", "apps/api/dist/index.js"]
