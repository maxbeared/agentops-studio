# ==========================================
# AgentOps Studio - Production Environment
# ==========================================

# Domain name for production
DOMAIN=your-domain.com

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=agentops

# Redis (no password for local Docker network)
REDIS_URL=redis://redis:6379

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# S3/MinIO Configuration
S3_ACCESS_KEY=minio
S3_SECRET_KEY=your_minio_password_here
S3_BUCKET=agentops

# AI API Keys (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Ports (default values)
PORT=3001
WS_PORT=3002
NEXT_PUBLIC_API_URL=http://your-domain.com
NEXT_PUBLIC_WS_URL=ws://your-domain.com
